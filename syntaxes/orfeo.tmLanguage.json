{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Orfeo",
    "scopeName": "source.orfeo",
    "fileTypes": [ "orfeo" ],
    "patterns": [
        { "include": "#pragma_end"},
        { "include": "#comment_block_#_end" },
        { "include": "#comment_block" },
        { "include": "#comment_line" },
        { "include": "#comment_atomic" },

        { "include": "#note-alone-muted" },
        { "include": "#note-alone" },

        { "include": "#note-first-muted" },
        { "include": "#note-first" },

        { "include": "#_muting-backslash-with-repeater-dash-dot-and-notes" },
        { "include": "#_muting-backslash-with-music-expression" },
        { "include": "#_muting-backslash_IS-NEEDED???" },
        { "include": "#_note-container" },
        { "include": "#_note-backtick" },
        { "include": "#_rest" },
        { "include": "#_duration" },
        { "include": "#_music-expression-duration" },
        { "include": "#_metronome" },
        { "include": "#_marker" },
        { "include": "#_rhythm-flags" },
        { "include": "#_rhythm-dots" },
        { "include": "#_repeater-dot" },
        { "include": "#_repeater-dash" },
        { "include": "#_barline" }
    ],
    "repository": {
        "pragma_end": {
            "name": "variable.parameter.pragma.end.orfeo",
            "match": "(?<=^\\s*)#_end(?=\\s*$)"
        },
        "comment_block_#_end": {
            "contentName": "comment.block.end.orfeo",
            "begin": "(?<=^\\s*#_end\\s*$)",
            "end": "(?=\\\\Z)"
        },
        "nested-parentheses": {
            "name": "comment.block.orfeo",
            "begin": "\\(",
            "end": "\\)",
            "patterns": [
                {
                    "include": "#nested-parentheses"
                }
            ]
        },
        "nested-pointy-bracket": {
            "name": "comment.block.orfeo",
            "begin": "<",
            "end": ">",
            "patterns": [
                {
                    "include": "#nested-pointy-bracket"
                }
            ]
        },
        "nested-square-bracket": {
            "name": "comment.block.orfeo",
            "begin": "\\[",
            "end": "\\]",
            "patterns": [
                {
                    "include": "#nested-square-bracket"
                }
            ]
        },
        "nested-curly-bracket": {
            "name": "comment.block.orfeo",
            "begin": "{",
            "end": "}",
            "patterns": [
                {
                    "include": "#nested-curly-bracket"
                }
            ]
        },
        "nested-guillemets": {
            "name": "comment.block.orfeo",
            "begin": "ยซ",
            "end": "ยป",
            "patterns": [
                {
                    "include": "#nested-guillemets"
                }
            ]
        },
        "nested-halfwidth-corner-bracket": {
            "name": "comment.block.orfeo",
            "begin": "๏ฝข",
            "end": "๏ฝฃ",
            "patterns": [
                {
                    "include": "#nested-halfwidth-corner-bracket"
                }
            ]
        },
        "comment_block": {
            "patterns": [
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*\\(",
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#nested-parentheses"
                        }
                    ]
                },
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*<",
                    "end": ">",
                    "patterns": [
                        {
                            "include": "#nested-pointy-bracket"
                        }
                    ]
                },
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*\\[",
                    "end": "\\]",
                    "patterns": [
                        {
                            "include": "#nested-square-bracket"
                        }
                    ]
                },
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*{",
                    "end": "}",
                    "patterns": [
                        {
                            "include": "#nested-curly-bracket"
                        }
                    ]
                },
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*ยซ",
                    "end": "ยป",
                    "patterns": [
                        {
                            "include": "#nested-guillemets"
                        }
                    ]
                },
                {
                    "name": "comment.block.orfeo",
                    "begin": "#\\\\?\\^*,*๏ฝข",
                    "end": "๏ฝฃ",
                    "patterns": [
                        {
                            "include": "#nested-halfwidth-corner-bracket"
                        }
                    ]
                }
            ]
        },
        "comment_line": {
            "name": "comment.line.number-sign.orfeo",
            "begin": "#\\s|##",
            "end": "$"
        },
        "comment_atomic": {
            "name": "comment.line.number-sign.atomic.orfeo",
            "match": "(?<=^|[\\s()])#[^\\s()]*(?=[\\s()]|$)"
        },




        "note-alone-muted": {
            "name": "comment.line.number-sign.strikethrough.orfeo",
            "match": "(?<=\\\\\\^*,*((\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?)?)[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผ](?=[\\s()]|$)"
        },
        "note-alone": {
            "name": "string.unquoted.orfeo",
            "match": "(?<=^|[\\s()\\^,\\d])[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผ](?=[\\s()]|$)"
        },


        "note-first-muted": {
            "name": "comment.line.number-sign.strikethrough.orfeo",
            "match": "(?<=\\\\\\^*,*((\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?)?)[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+](?=[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-+/'._0-9])"
        },
        "note-first": {
            "name": "string.unquoted.orfeo",
            "match": "(?<=^|[\\s()\\^,\\d])[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+](?=[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-+/'._0-9])"
        },




        "muting-backslash-with-repeater-dash-dot-and-notes": {
            "captures": {
                "1": { "name": "keyword.other.orfeo" },
                "2": { "name": "constant.character.orfeo" },
                "3": { "name": "variable.other.orfeo" },
                "11": { "name": "comment.line.number-sign.strikethrough.orfeo" }
            },
            "match": "(?<=^|[\\s()])(\\\\)(\\^*,*)((\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?)?(-|\\.|<[^>]*>|(`[^\\s()]+)|(([a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+][a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-+/'._0-9]*[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-'!?._0-9])|[a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผ]))(?=[\\s()]|$)"
        },
        "muting-backslash-with-music-expression": {
            "captures": {
                "1": { "name": "keyword.other.orfeo" },
                "2": { "name": "constant.character.orfeo" },
                "3": { "name": "comment.line.number-sign.strikethrough.orfeo" }
            },
            "match": "(?<=^|[\\s()])(\\\\)(\\^*,*)(\\([^\\(]*(\\([^\\(]*(\\([^\\(]*(\\([^\\(]*(\\([^\\(]*\\)[^\\(]*)*\\)[^\\(]*)*\\)[^\\(]*)*\\)[^\\(]*)*\\))(?=[\\s()]|$)"
        },
        "muting-backslash": {
            "name": "keyword.other.orfeo",
            "match": "(?<=^|[\\s()])\\\\(?=[\\^,\\d(])"
        },
        "note-container": {
            "name": "string.quoted.other.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^,\\d])<[^>]*>(?=[\\s()]|$)"
        },
        "note-backtick": {
            "name": "string.quoted.other.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^,\\d])`[^\\s()]+(?=[\\s()]|$)"
        },
        "rest": {
            "name": "constant.character.rest.orfeo",
            "match": "(?<=^|[\\s()\\^,\\d])_(?=[\\s()]|$)"
        },
        "duration": {
            "name": "constant.numeric.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^,])(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?(?=[<`a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+_])"
        },
        "music-expression-duration": {
            "name": "variable.other.orfeo",
            "match": "(?<=^|[\\s()|])=(f|flex|(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?)(?=[\\s()]|$)"
        },
        "metronome": {
            "name": "variable.other.orfeo",
            "match": "(?<=^|[\\s()])(;|โฉ)(\\+|-)?(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?)(/(\\.\\d+|(0|[1-9]\\d*)(\\.\\d+)?))?(s|seconds|ms|milliseconds)?(?=[\\s()]|$)"
        },
        "marker": {
            "name": "variable.other.orfeo",
            "match": "(?<=^|[\\s()])@[a-zA-Z\\d'_.-]*[a-zA-Z\\d'](?=[\\s()]|$)"
        },
        "rhythm-flags": {
            "name": "keyword.other.orfeo",
            "match": "(?<=^|[\\s()\\\\])\\^+(?=[,\\d(<`a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+_])"
        },
        "rhythm-dots": {
            "name": "keyword.other.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^]),+(?=[\\d(<`a-zA-Zรกรฉรญรณรบรรรรรรขรชรฎรดรปรรรรรร รจรนรรรรซรฏรผรรรรงรรฑรแญกแญขแญฃแญคแญฅแญฆแญงแญจแญฉแญชแญดแญตแญถแญทแญธแญนแญบแญปแญผโฎโญโฏ\\-ยกยฟ+_])"
        },
        "repeater-dot": {
            "name": "constant.character.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^,\\d])\\.(?=[\\s()]|$)"
        },
        "repeater-dash": {
            "name": "constant.character.orfeo",
            "match": "(?<=^|[\\s()\\\\\\^,\\d])\\-(?=[\\s()]|$)"
        },
        "barline": {
            "name": "keyword.other.orfeo",
            "match": "(?<=^|\\s)\\|(?=[\\s=]|$)"
        }
    }
}
